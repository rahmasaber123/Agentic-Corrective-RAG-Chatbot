        "## 5. Data Loading & Vector Store\n",
        "\n",
        "Loads the Rasheqa knowledge base from a local JSON file, builds `Document` objects\n",
        "with rich metadata, and indexes them in ChromaDB.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "id": "8e01e493",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "8e01e493",
        "outputId": "9004bf1f-11d7-405c-856e-6ece5cc9313f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Created 5 documents ✅\n"
          ]
        }
      ],
      "source": [
        "with open(\"/content/rasheqa_knowledge_base.json\", \"r\", encoding=\"utf-8\") as f:\n",
        "    data = json.load(f)\n",
        "\n",
        "programs = data[\"programs\"]\n",
        "\n",
        "docs_list = []\n",
        "for p in programs:\n",
        "    full_program_text = f\"\"\"\n",
        "    Program Name: {p['name']}\n",
        "    BMI Range: {p['bmi_min']} - {p['bmi_max']}\n",
        "    Advantages: {', '.join(p['advantages'])}\n",
        "    Best For: {', '.join(p['best_for'])}\n",
        "    Tags: {', '.join(p['tags'])}\n",
        "    \"\"\"\n",
        "    docs_list.append(\n",
        "        Document(\n",
        "            page_content=full_program_text.strip(),\n",
        "            metadata={\n",
        "                \"id\":      p[\"id\"],\n",
        "                \"name\":    p[\"name\"],\n",
        "                \"bmi_min\": p[\"bmi_min\"],\n",
        "                \"bmi_max\": p[\"bmi_max\"],\n",
        "                \"tags\":    p[\"tags\"],\n",
        "                \"link\":    p[\"link\"],\n",
        "            },\n",
        "        )\n",
        "    )\n",
        "print(f\"Created {len(docs_list)} documents ✅\")\n"
      ]
    },
    {

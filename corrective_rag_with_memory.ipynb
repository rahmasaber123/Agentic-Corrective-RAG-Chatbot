      "source": [
        "class GradeDocuments(BaseModel):\n",
        "    binary_score: str = Field(description=\"'yes' if relevant, 'no' otherwise\")\n",
        "\n",
        "structured_llm_grader = llm.with_structured_output(GradeDocuments)\n",
        "retrieval_grader = grade_prompt | structured_llm_grader\n",
        "\n",
        "question_rewriter = re_write_prompt | llm | StrOutputParser()\n",
        "\n",
        "web_search_tool = TavilySearchResults(k=3)\n",
        "print(\"All chains and tools ready ✅\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "456d5bd6",
      "metadata": {
        "id": "456d5bd6"
      },
      "source": [
        "## 9. Graph State\n",
        "\n",
        "The `State` TypedDict carries all information through the pipeline.\n",
        "\n",
        "`chat_history` has been **added** to the existing fields — nothing else was changed.\n",
        "\n",
        "| Field | Type | Description |\n",
        "|---|---|---|\n",
        "| `question` | `str` | Current (possibly rewritten) query |\n",
        "| `generation` | `str` | Final LLM answer |\n",
        "| `web_search` | `str` | `\"Yes\"` / `\"No\"` flag |\n",
        "| `documents` | `List[Document]` | Filtered document list |\n",
        "| `route` | `str` | Router decision (`\"rag\"` / `\"web\"`) |\n",
        "| `scope` | `str` | Scope guard result (`\"in_scope\"` / `\"out_of_scope\"`) |\n",
        "| `chat_history` | `list` | **[NEW]** Last ≤10 conversation turns from memory |\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 14,
      "id": "f7528512",
      "metadata": {
        "id": "f7528512"
      },
      "outputs": [],
      "source": [
        "class State(TypedDict):\n",
        "    question:     str\n",
        "    generation:   str\n",
        "    web_search:   str\n",
        "    documents:    List[Document]\n",
        "    route:        str\n",
        "    scope:        str\n",
        "    chat_history: list          # ← added for conversational memory\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "5ca869ee",
      "metadata": {
        "id": "5ca869ee"
      },
      "source": [
        "## 10. Nodes\n",
        "\n",
        "### 10.1 `retrieve`\n",
        "Retrieves top-k documents from the vector store.\n",
        "**Memory addition:** loads `chat_history` from memory and injects it into the state\n",
        "so downstream nodes (especially `generate`) can access it.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 15,
      "id": "2a921c31",
      "metadata": {
        "id": "2a921c31"
      },
      "outputs": [],
      "source": [
        "def retrieve(state):\n",
        "    print(\"---RETRIEVE---\")\n",
        "\n",
        "    question = state[\"question\"]\n",
        "\n",
        "    chat_history = get_session_history(\"user_1\").messages\n",
        "\n",
        "    documents = retriever.invoke(question)\n",
        "\n",
        "    return {\n",
        "        \"documents\": documents,\n",
        "        \"question\": question,\n",
        "        \"chat_history\": chat_history\n",
        "    }"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "012bcd2d",
      "metadata": {
        "id": "012bcd2d"
      },
      "source": [
        "### 10.2 `grade_documents`\n",
        "Scores every retrieved document for relevance.\n",
        "Sets `web_search = \"Yes\"` if **any** document is irrelevant.\n",
        "*(Unchanged.)*\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 16,
      "id": "0566d85c",
      "metadata": {
        "id": "0566d85c"
      },
      "outputs": [],
      "source": [
        "def grade_documents(state: State):\n",
        "    print(\"---GRADING DOCUMENTS---\")\n",
        "    question      = state[\"question\"]\n",
        "    documents     = state[\"documents\"]\n",
        "    filtered_docs = []\n",
        "    web_search    = \"No\"\n",
        "\n",
        "    for d in documents:\n",
        "        score = retrieval_grader.invoke({\"question\": question, \"document\": d.page_content})\n",
        "        if score.binary_score == \"yes\":\n",
        "            print(\"  ✅ Relevant\")\n",
        "            filtered_docs.append(d)\n",
        "        else:\n",
        "            print(\"  ❌ Not relevant — will trigger web search\")\n",
        "            web_search = \"Yes\"\n",
        "\n",
        "    return {\"documents\": filtered_docs, \"question\": question, \"web_search\": web_search}\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "db1bcb97",
      "metadata": {
        "id": "db1bcb97"
      },
      "source": [
        "### 10.3 `route_query`\n",
        "LLM-based router: decides between answering from the knowledge base (`rag`) or\n",
        "performing a web search (`web`).\n",
        "*(Unchanged.)*\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 17,
      "id": "601146ce",
      "metadata": {
        "id": "601146ce"
      },
      "outputs": [],
      "source": [
        "def route_query(state):\n",
        "    q = state[\"question\"]\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "    Answer ONLY one word: rag or web\n",
        "\n",
        "    Question: {q}\n",
        "    \"\"\"\n",
        "\n",
        "    decision = llm.invoke(prompt).content.strip().lower()\n",
        "\n",
        "    # 🔥 sanitize قوي\n",
        "    if \"rag\" == decision:\n",
        "        route = \"rag\"\n",
        "    elif \"web\" == decision:\n",
        "        route = \"web\"\n",
        "    else:\n",
        "        route = \"web\"   # fallback\n",
        "\n",
        "    print(f\"---ROUTER--- → {route}\")\n",
        "\n",
        "    return {**state, \"route\": route}"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "573abf23",
      "metadata": {
        "id": "573abf23"
      },
      "source": [
        "### 10.4 `generate`\n",
        "Generates the final answer.\n",
        "\n",
        "**Memory additions:**\n",
        "1. Extracts `chat_history` from state and formats it via `format_chat_history`.\n",
        "2. Injects the formatted history into the prompt **before** the question.\n",
        "3. Saves the new `(question, answer)` pair back into memory after generation.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 18,
      "id": "358dc597",
      "metadata": {
        "id": "358dc597"
      },
      "outputs": [],
      "source": [
        "def generate(state):\n",
        "    print(\"---GENERATE---\")\n",
        "\n",
        "    context = (\n",
        "        format_docs(state[\"documents\"])\n",
        "        if isinstance(state[\"documents\"], list)\n",
        "        else state[\"documents\"]\n",
        "    )\n",
        "\n",
        "    history = format_chat_history(state.get(\"chat_history\", []))\n",
        "\n",
        "    response = chain.invoke(\n",
        "        {\n",
        "            \"question\": state[\"question\"],\n",
        "            \"context\": context,\n",
        "            \"history\": history\n",
        "        },\n",
        "        config={\"configurable\": {\"session_id\": \"user_1\"}}\n",
        "    )\n",
        "\n",
        "    return {**state, \"generation\": response.content}"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "ea4cc385",
      "metadata": {
        "id": "ea4cc385"
      },
      "source": [
        "### 10.5 `transform_query`\n",
        "Rewrites the question for better web-search recall.\n",
        "*(Unchanged.)*\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 19,
      "id": "ab2200a9",
      "metadata": {
        "id": "ab2200a9"
      },
      "outputs": [],
      "source": [
        "def transform_query(state: State):\n",
        "    print(\"---TRANSFORM QUERY---\")\n",
        "    question        = state[\"question\"]\n",
        "    better_question = question_rewriter.invoke({\"question\": question})\n",
        "    print(f\"Rewritten: {better_question}\")\n",
        "    return {\"documents\": state[\"documents\"], \"question\": better_question}\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "2958e2b4",
      "metadata": {
        "id": "2958e2b4"
      },
      "source": [
        "### 10.6 `web_search`\n",
        "Queries Tavily and appends web results to the document list.\n",
        "*(Unchanged.)*\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 20,
      "id": "045fa10c",
      "metadata": {
        "id": "045fa10c"
      },
      "outputs": [],
      "source": [
        "def web_search(state: State):\n",
        "    print(\"---WEB SEARCH---\")\n",
        "    question  = state[\"question\"]\n",
        "    documents = state[\"documents\"]\n",
        "    results   = web_search_tool.invoke({\"query\": question})\n",
        "    web_content = \"\\n\".join([d[\"content\"] for d in results])\n",
        "    documents.append(Document(page_content=web_content))\n",
        "    return {\"documents\": documents, \"question\": question}\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "e2713f03",
      "metadata": {
        "id": "e2713f03"
      },
      "source": [
        "### 10.7 `scope_check` & `reject`\n",
        "Out-of-scope guard for questions unrelated to diet / nutrition / fitness.\n",
        "*(Unchanged.)*\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 21,
      "id": "bef6e069",
      "metadata": {
        "id": "bef6e069"
      },
      "outputs": [],
      "source": [
        "import re\n",
        "\n",
        "def scope_check(state):\n",
        "    q = state[\"question\"].lower().strip()\n",
        "\n",
        "    # greetings\n",
        "    greetings = [\"hello\", \"hi\", \"hey\", \"مرحبا\", \"اهلا\", \"السلام\"]\n",
        "\n",
        "    # diet keywords\n",
        "    keywords = [\n",
        "        \"دايت\", \"تخسيس\", \"وزن\", \"شهية\",\n",
        "        \"حمية\", \"برنامج\", \"رجيم\",\n",
        "        \"diet\", \"nutrition\", \"weight\"\n",
        "    ]\n",
        "\n",
        "    is_greeting = any(g in q for g in greetings)\n",
        "    is_diet = any(k in q for k in keywords)\n",
        "\n",
        "    scope = \"in_scope\" if (is_greeting or is_diet) else \"out_of_scope\"\n",
        "\n",
        "    return {**state, \"scope\": scope}\n",
        "\n",
        "\n",
        "def reject(state):\n",
        "    q = state[\"question\"]\n",
        "\n",
        "    is_arabic = any(\"\\u0600\" <= c <= \"\\u06FF\" for c in q)\n",
        "\n",
        "    if is_arabic:\n",
        "        msg = \"أقدر أساعدك في الدايت والتغذية بس 💪\"\n",
        "    else:\n",
        "        msg = \"I can help with diet and nutrition only 💪\"\n",
        "\n",
        "    return {**state, \"generation\": msg}\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "eb7f6308",
      "metadata": {
        "id": "eb7f6308"
      },
      "source": [
        "## 11. Decision Functions (Conditional Edges)\n",
        "\n",
        "These routing functions are **unchanged** — only their placement has moved here\n",
        "for clarity.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 22,
      "id": "375b85ee",
      "metadata": {
        "id": "375b85ee"
      },
      "outputs": [],
      "source": [
        "def decide_to_generate(state):\n",
        "    print(\"---ROUTING---\")\n",
        "\n",
        "    if state[\"web_search\"] == \"Yes\":\n",
        "        print(\"  → Go to router\")\n",
        "        return \"route_query\"   # ✅ string\n",
        "\n",
        "    print(\"  → Generate directly\")\n",
        "    return \"generate\"          # ✅ string\n",
        "\n",
        "def route_decision(state):\n",
        "    q = state[\"question\"].lower().strip()\n",
        "\n",
        "    greetings = [\"hello\", \"hi\", \"hey\", \"مرحبا\", \"اهلا\", \"السلام\"]\n",
        "\n",
        "    if any(g in q for g in greetings):\n",
        "        return \"generate\"\n",
        "\n",
        "    if state.get(\"route\") == \"rag\":\n",
        "        return \"generate\"\n",
        "\n",
        "    return \"scope_check\"\n",
        "\n",
        "def scope_decision(state):\n",
        "    return \"generate\" if state[\"scope\"] == \"in_scope\" else \"reject\"\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "e0d7aeb2",
      "metadata": {
        "id": "e0d7aeb2"
      },
      "source": [
        "## 12. Graph Definition & Compilation"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 23,
      "id": "a9676954",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "a9676954",
        "outputId": "5c658b9e-56cb-4531-cece-3def4fa26bd4"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Graph ready ✅\n"
          ]
        }
      ],
      "source": [
        "workflow = StateGraph(State)\n",
        "\n",
        "# ── Nodes ──────────────────────────────────────────────────────────────────\n",
        "workflow.add_node(\"retrieve\",        retrieve)\n",
        "workflow.add_node(\"grade_documents\", grade_documents)\n",
        "workflow.add_node(\"route_query\",     route_query)\n",
        "workflow.add_node(\"scope_check\",     scope_check)\n",
        "workflow.add_node(\"transform_query\", transform_query)\n",
        "workflow.add_node(\"web_search_node\", web_search)\n",
        "workflow.add_node(\"generate\",        generate)\n",
        "workflow.add_node(\"reject\",          reject)\n",
        "\n",
        "# ── Flow ───────────────────────────────────────────────────────────────────\n",
        "workflow.add_edge(START, \"retrieve\")\n",
        "workflow.add_edge(\"retrieve\", \"grade_documents\")\n",
        "\n",
        "# 1) Decide RAG vs routing\n",
        "workflow.add_conditional_edges(\n",
        "    \"grade_documents\",\n",
        "    decide_to_generate,\n",
        "    {\n",
        "        \"generate\": \"generate\",\n",
        "        \"route_query\": \"route_query\",\n",
        "    },\n",
        ")\n",
        "\n",
        "workflow.add_conditional_edges(\n",
        "    \"route_query\",\n",
        "    route_decision,\n",
        "    {\n",
        "        \"generate\": \"generate\",\n",
        "        \"scope_check\": \"scope_check\",\n",
        "    },\n",
        ")\n",
        "# 3) Scope guard (🔥 ONLY for web)\n",
        "workflow.add_conditional_edges(\n",
        "    \"scope_check\",\n",
        "    scope_decision,\n",
        "    {\n",
        "        \"generate\":        \"generate\",      # 👈 أضف ده\n",
        "        \"transform_query\": \"transform_query\",\n",
        "        \"reject\":          \"reject\",\n",
        "    },\n",
        ")\n",
        "\n",
        "# 4) Web flow\n",
        "workflow.add_edge(\"transform_query\", \"web_search_node\")\n",
        "workflow.add_edge(\"web_search_node\", \"generate\")\n",
        "\n",
        "# ── Terminals ─────────────────────────────────────────────────────────────\n",
        "workflow.add_edge(\"generate\", END)\n",
        "workflow.add_edge(\"reject\",   END)\n",
        "\n",
        "app = workflow.compile()\n",
